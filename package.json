{
  "name": "github-pr-dashboard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Dev tooling root: ESLint + Prettier orchestrating backend / frontend / ai-server.",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.5",
  "scripts": {
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "9.17.0",
    "eslint": "9.17.0",
    "eslint-config-prettier": "9.1.0",
    "globals": "15.14.0",
    "prettier": "3.4.2"
  }
}
